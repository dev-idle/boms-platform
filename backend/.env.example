# =============================================================================
# BOMS API — Environment configuration
# Copy to .env and adjust values. Never commit .env to version control.
# Durations use Go syntax (e.g. 15s, 2m, 1h). See time.ParseDuration.
#
# Local stack: Docker = Redis only. PostgreSQL = Neon (https://neon.tech).
#   docker compose -f scripts/docker-compose.dev.yml up -d
# =============================================================================

# Application
APP_NAME=boms-api
APP_ENV=development
APP_DEBUG=false

# HTTP
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
HTTP_BODY_LIMIT=1048576
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=120s
# Comma-separated CIDRs of reverse proxies; empty = direct clients. Sets X-Forwarded-For trust + Fiber ProxyHeader.
HTTP_TRUSTED_PROXIES=
# HSTS: max-age seconds on Strict-Transport-Security; 0 = off (use TLS at reverse proxy; enable when appropriate)
HTTP_HSTS_MAX_AGE=0

# CORS (comma-separated origins)
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400

# Rate limit (per IP, in-memory)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=60s

# PostgreSQL — Neon (dashboard → connection string; prefer sslmode=require)
# staging/production: sslmode=disable|allow rejected by config.
POSTGRES_URL=
POSTGRES_MAX_CONNS=25
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=15m
POSTGRES_HEALTH_TIMEOUT=5s

# Redis — local Docker (see scripts/docker-compose.dev.yml)
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=2s
REDIS_READ_TIMEOUT=2s
REDIS_WRITE_TIMEOUT=2s
REDIS_HEALTH_TIMEOUT=2s

# Asynq client only (no workers in this foundation)
ASYNQ_ENABLED=false

# Logging
LOG_LEVEL=info
LOG_ENCODING=json
LOG_ENABLE_CALLER=false
LOG_ENABLE_STACKTRACE=false

# JWT (required length in staging/production — see config validation)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
