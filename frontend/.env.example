# Go Fiber API origin (no trailing slash)
BOMS_BACKEND_URL=http://127.0.0.1:8080

# Minimum 32 characters; must match what Fiber expects on X-Internal-Secret
INTERNAL_PROXY_SECRET=change-me-to-a-long-random-secret-at-least-32

# Canonical public URL (no trailing slash) — used for metadataBase and absolute URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
